<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:EntertainmentCenter"
             xmlns:converters="clr-namespace:EntertainmentCenter.Converters"
             x:Class="EntertainmentCenter.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:BooleanInvertConverter x:Key="InvertBool" />
            <converters:BoolToColorConverter x:Key="BoolToColor" />
            <converters:BoolToBorderColorConverter x:Key="BoolToBorderColor" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
