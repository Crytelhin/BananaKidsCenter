<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:EntertainmentCenter.ViewModels"
    xmlns:strings="clr-namespace:EntertainmentCenter.Resources.Strings"
    x:Class="EntertainmentCenter.Views.ServerConnectionPage"
    x:DataType="vm:ServerConnectionViewModel"
    Title="{x:Static strings:AppResources.ServerConnection}"
    BackgroundColor="{StaticResource Background}">

    <VerticalStackLayout Padding="16" Spacing="16">

        <!-- Error -->
        <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Danger}" FontSize="14"
               IsVisible="{Binding ErrorMessage, Converter={x:Null}}" />

        <!-- IP Address -->
        <Frame Style="{StaticResource CardStyle}">
            <VerticalStackLayout Spacing="8">
                <Label Text="{x:Static strings:AppResources.ServerIpOrName}" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                <Entry Placeholder="http://192.168.1.100:5000" Text="{Binding ApiUrl}"
                       Keyboard="Url" />
                <Label Text="{x:Static strings:AppResources.ServerIpExample}"
                       FontSize="11" TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>
        </Frame>

        <!-- Status Indicator -->
        <Frame CornerRadius="10" Padding="12,10" HasShadow="False"
               BorderColor="{StaticResource Border}" BackgroundColor="{StaticResource Surface}"
               IsVisible="{Binding ShowStatus}">
            <HorizontalStackLayout Spacing="8">
                <!-- Connnected dot -->
                <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5"
                         Color="{Binding StatusColor}" VerticalOptions="Center" />
                <Label Text="{Binding StatusText}" FontSize="14"
                       TextColor="{Binding StatusColor}" VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Frame>

        <!-- Connect button -->
        <Button Text="{x:Static strings:AppResources.Connect}" Style="{StaticResource ButtonPrimary}"
                Command="{Binding ConnectCommand}" />

        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center" />

    </VerticalStackLayout>
</ContentPage>
